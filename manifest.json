{
  "manifest_version": 3,
  "name": "Converse — Search for Claude",
  "version": "1.0.0",
  "description": "Full-text search across all your Claude conversations. Find anything, instantly.",
  "author": "Mehran",
  "homepage_url": "https://github.com/meh7an/converse-chrome",

  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "clipboardRead"
  ],

  "host_permissions": [
    "https://claude.ai/*"
  ],

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["browser-polyfill.js", "storage.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Converse — Search your conversations"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
